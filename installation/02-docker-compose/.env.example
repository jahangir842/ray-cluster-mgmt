# ─── Ray Base Image ─────────────────────────────────────────────────────────
# Official rayproject images: https://hub.docker.com/r/rayproject/ray/tags
# CPU:  rayproject/ray:<version>-py311
# GPU:  rayproject/ray:<version>-py311-gpu
BASE_IMAGE=rayproject/ray:2.47.0-py311

# ─── Cluster Network ────────────────────────────────────────────────────────
RAY_HEAD_HOST=192.168.3.73
RAY_GCS_PORT=6379
RAY_DASHBOARD_PORT=8265
RAY_CLIENT_PORT=10001

# ─── Head Node Resources ────────────────────────────────────────────────────
HEAD_NUM_CPUS=4
HEAD_OBJECT_STORE_MEMORY=4000000000      # 4 GB

# ─── Worker Node Resources ──────────────────────────────────────────────────
# Single-host mode: these are per-container values
# Multi-node mode:  these reflect the physical host's allocatable resources
WORKER_NUM_CPUS=32
WORKER_NUM_GPUS=1
WORKER_OBJECT_STORE_MEMORY=8000000000    # 8 GB

# Number of worker containers (single-host mode only)
WORKER_REPLICAS=2

# ─── Shared Storage ─────────────────────────────────────────────────────────
# Must be a path that exists on every node (e.g. NFS mount)
SHARED_STORAGE_PATH=/mnt/cluster_storage

# ─── Network Interfaces (NCCL / Gloo for multi-GPU comms) ──────────────────
# Run `ip link` on each node to confirm interface names.
# Comma-separated list; exact interface name only — no IP prefixes.
NCCL_SOCKET_IFNAME=enp0s31f6,eno1
GLOO_SOCKET_IFNAME=enp0s31f6,eno1

# ─── Multi-node SSH Deploy (scripts/deploy-cluster.sh) ──────────────────────
# Space-separated list of worker node IPs / hostnames.
# The head node itself is not listed here.
WORKER_HOSTS="192.168.3.74 192.168.3.75 192.168.3.76 192.168.3.77 192.168.3.78 192.168.3.79 192.168.3.80"
SSH_USER=ubuntu
